<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NotifyVault" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/wa_green_light</item>
        <item name="colorSecondary">@color/wa_green</item>
        <item name="android:statusBarColor">@color/wa_surface_dark</item>
        <item name="android:navigationBarColor">@color/wa_background_dark</item>
        <item name="android:windowBackground">@color/wa_background_dark</item>
    </style>

    <style name="Theme.App.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/wa_background_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/wa_green_dark</item>
        <item name="postSplashScreenTheme">@style/Theme.NotifyVault</item>
    </style>
</resources>
